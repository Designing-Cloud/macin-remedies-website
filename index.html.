<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<meta name="cf-2fa-verify" content="disable-email-obfuscation">
<title>Macin Remedies India Ltd. – Innovating Today for a Healthier Tomorrow</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --teal:#006666; --dark-teal:#004444; --mid-teal:#008080;
  --light-teal:#e0f2f1; --grey:#607D8B;
  --off-white:#fff5f7; --text:#2c3e3e;
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'DM Sans',sans-serif;background:var(--off-white);color:var(--text);overflow-x:hidden;-webkit-text-size-adjust:100%;}
a{text-decoration:none;}

/* ── NAV ── */
nav{
  position:fixed;top:0;left:0;right:0;z-index:1000;
  height:82px;
  background:rgba(0,36,36,0.97);
  backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);
  border-bottom:1px solid rgba(0,128,128,0.28);
  display:flex;align-items:center;justify-content:space-between;
  padding:0 5%;transition:height .3s;
}
.nav-logo-link{display:flex;align-items:center;}
.nav-logo-img{height:76px;width:auto;object-fit:contain;display:block;}
.nav-links{display:flex;gap:1.8rem;list-style:none;}
.nav-links a{color:rgba(255,245,247,.75);font-size:.82rem;font-weight:500;letter-spacing:.06em;text-transform:uppercase;transition:color .2s;}
.nav-links a:hover{color:#5bc8c8;}
.nav-cta{background:var(--mid-teal);color:#fff5f7;padding:.46rem 1.3rem;border-radius:5px;font-size:.82rem;font-weight:600;letter-spacing:.05em;transition:background .2s;white-space:nowrap;}
.nav-cta:hover{background:#009999;}
.hamburger{display:none;flex-direction:column;justify-content:center;align-items:center;width:44px;height:44px;cursor:pointer;gap:5px;background:none;border:none;-webkit-tap-highlight-color:transparent;}
.hamburger span{display:block;width:24px;height:2px;background:#fff5f7;border-radius:2px;transition:all .3s;}
.hamburger.open span:nth-child(1){transform:translateY(7px) rotate(45deg);}
.hamburger.open span:nth-child(2){opacity:0;}
.hamburger.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg);}
.mobile-menu{display:none;position:fixed;top:64px;left:0;right:0;bottom:0;z-index:999;background:rgba(0,24,24,.98);flex-direction:column;align-items:center;justify-content:center;gap:1.8rem;transform:translateX(100%);transition:transform .35s cubic-bezier(.4,0,.2,1);}
.mobile-menu.open{transform:translateX(0);}
.mobile-menu a{color:#fff5f7;font-size:1.6rem;font-weight:700;font-family:'Playfair Display',serif;letter-spacing:.03em;transition:color .2s;padding:.4rem 2rem;}
.mobile-menu a:hover{color:#5bc8c8;}
.mobile-menu .mob-cta{background:var(--mid-teal);color:#fff5f7;padding:.9rem 2.8rem;border-radius:8px;font-size:1rem;font-family:'DM Sans',sans-serif;font-weight:600;margin-top:.5rem;}

/* ── HERO ── */
#hero{
  min-height:100vh;min-height:100dvh;
  background:linear-gradient(135deg,#002828 0%,#004444 40%,#006060 70%,#003030 100%);
  display:flex;flex-direction:column;justify-content:center;align-items:center;
  text-align:center;position:relative;overflow:hidden;
  padding:100px 6% 60px;
}
#hero::before{content:'';position:absolute;inset:0;background-image:linear-gradient(rgba(0,128,128,.06) 1px,transparent 1px),linear-gradient(90deg,rgba(0,128,128,.06) 1px,transparent 1px);background-size:50px 50px;z-index:0;}
.hero-orb{position:absolute;border-radius:50%;background:radial-gradient(circle,rgba(0,150,150,.15) 0%,transparent 70%);animation:float 8s ease-in-out infinite;pointer-events:none;}
.orb1{width:500px;height:500px;top:-120px;right:-80px;}
.orb2{width:350px;height:350px;bottom:-80px;left:-60px;animation-delay:3s;}
.orb3{width:250px;height:250px;top:35%;left:10%;animation-delay:5s;}
@keyframes float{0%,100%{transform:translateY(0) scale(1);}50%{transform:translateY(-25px) scale(1.04);}}
.hero-content{position:relative;z-index:1;max-width:800px;width:100%;}
.hero-badge{display:inline-block;background:rgba(0,128,128,.22);border:1px solid rgba(0,200,200,.3);color:#7de0e0;padding:.33rem 1rem;border-radius:50px;font-size:.7rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;margin-bottom:1.5rem;animation:fadeDown .8s ease both;}
.hero-title{font-family:'Playfair Display',serif;font-size:clamp(2.4rem,8vw,5rem);font-weight:900;color:#fff5f7;line-height:1.08;margin-bottom:.4rem;animation:fadeDown .9s .1s ease both;}
.hero-title span{color:#5bc8c8;}
.hero-sub{font-family:'Playfair Display',serif;font-size:clamp(1rem,3.5vw,1.7rem);color:rgba(255,245,247,.5);font-weight:400;margin-bottom:1.2rem;animation:fadeDown 1s .2s ease both;}
.hero-tagline{font-size:clamp(1rem,2.8vw,1.25rem);color:rgba(255,245,247,.9);font-style:italic;margin-bottom:2.5rem;animation:fadeDown 1s .3s ease both;letter-spacing:.03em;padding:.55rem 1.4rem;border-left:3px solid #5bc8c8;border-right:3px solid #5bc8c8;display:inline-block;}
.hero-actions{display:flex;gap:.9rem;justify-content:center;flex-wrap:wrap;animation:fadeDown 1s .4s ease both;}
.btn-primary{background:var(--mid-teal);color:#fff5f7;padding:.82rem 1.9rem;border-radius:6px;font-size:.9rem;font-weight:600;letter-spacing:.04em;transition:all .25s;min-width:145px;text-align:center;}
.btn-primary:hover{background:#009999;transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,128,128,.4);}
.btn-outline{border:1.5px solid rgba(255,245,247,.3);color:#fff5f7;padding:.82rem 1.9rem;border-radius:6px;font-size:.9rem;font-weight:500;transition:all .25s;min-width:145px;text-align:center;}
.btn-outline:hover{border-color:#5bc8c8;color:#5bc8c8;}
.hero-stats{display:flex;flex-wrap:wrap;gap:1.5rem;justify-content:center;margin-top:3.5rem;padding-top:2rem;border-top:1px solid rgba(255,245,247,.1);animation:fadeUp 1s .6s ease both;}
.stat-item{text-align:center;min-width:75px;}
.stat-num{font-family:'Playfair Display',serif;font-size:clamp(1.5rem,5vw,2.2rem);font-weight:900;color:#5bc8c8;display:block;}
.stat-label{font-size:.66rem;color:rgba(255,245,247,.42);text-transform:uppercase;letter-spacing:.1em;margin-top:.2rem;}
@keyframes fadeDown{from{opacity:0;transform:translateY(-18px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeUp{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:translateY(0)}}

/* ── COMMON ── */
section{padding:5rem 6%;}
.section-tag{display:inline-block;color:var(--mid-teal);font-size:.72rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;margin-bottom:.7rem;}
.section-title{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,5vw,2.8rem);font-weight:700;color:var(--dark-teal);line-height:1.2;margin-bottom:1rem;}
.section-desc{font-size:.95rem;color:var(--grey);line-height:1.75;max-width:580px;}

/* ── ABOUT ── */
#about{background:var(--off-white);}
.about-grid{
  display:grid;grid-template-columns:1fr 1fr;
  gap:3.5rem;align-items:stretch;
  max-width:1200px;margin:0 auto;
}
/* Left column — card + address stretch to full column height */
#about .about-grid > .reveal:first-child{
  display:flex;flex-direction:column;gap:0;
}
.about-card-main{
  background:linear-gradient(135deg,var(--dark-teal),var(--teal));
  border-radius:18px 18px 0 0;padding:2.4rem 2.2rem 2rem;
  color:#fff5f7;position:relative;overflow:hidden;
}
.about-card-main::before{
  content:'';position:absolute;top:-40px;right:-40px;
  width:160px;height:160px;border-radius:50%;
  background:rgba(255,245,247,.05);
}
.about-year{
  font-family:'Playfair Display',serif;
  font-size:clamp(3rem,10vw,4.5rem);font-weight:900;
  color:rgba(255,245,247,.1);line-height:1;margin-bottom:-.6rem;
}
.about-card-main h3{
  font-family:'Playfair Display',serif;
  font-size:1.4rem;font-weight:700;
  margin-bottom:.8rem;letter-spacing:.01em;
}
.about-card-main p{
  font-size:.91rem;line-height:1.78;opacity:.88;
  max-width:100%;
}
.about-tags{display:flex;flex-wrap:wrap;gap:.45rem;margin-top:1.3rem;}
.tag{
  background:rgba(255,245,247,.12);
  border:1px solid rgba(255,245,247,.22);
  color:#fff5f7;padding:.28rem .85rem;
  border-radius:50px;font-size:.73rem;letter-spacing:.03em;
}
/* Address block — stretches to fill remaining column height */
.about-mini{
  display:flex;align-items:center;gap:.9rem;
  background:var(--off-white);
  border-radius:0 0 14px 14px;
  border:1px solid var(--light-teal);
  border-top:none;
  padding:1.2rem 1.4rem;
  margin:0;
  flex:1;
  box-shadow:0 6px 20px rgba(0,60,60,.08);
}
.mini-icon{font-size:1.5rem;flex-shrink:0;}
.mini-text strong{display:block;font-size:.88rem;color:var(--dark-teal);font-weight:700;line-height:1.3;}
.mini-text span{font-size:.74rem;color:var(--grey);margin-top:.1rem;display:block;}
/* Right column */
#about .about-grid > .reveal:last-child{
  padding-top:.4rem;
}
.about-points{list-style:none;margin-top:1.6rem;}
.about-points li{
  display:flex;align-items:flex-start;gap:1rem;
  padding:.9rem 0;
  border-bottom:1px solid var(--light-teal);
}
.about-points li:last-child{border-bottom:none;padding-bottom:0;}
.point-dot{
  width:8px;height:8px;border-radius:50%;
  background:var(--mid-teal);flex-shrink:0;margin-top:5px;
}
.about-points li p{
  font-size:.9rem;color:var(--text);
  line-height:1.65;margin:0;
}

/* ── CERTIFICATIONS ── */
#certifications{background:var(--off-white);}
.cert-wrapper{max-width:1200px;margin:0 auto;}
.cert-header{text-align:center;margin-bottom:3rem;}
.cert-header .section-desc{margin:0 auto;}
.cert-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1.2rem;}
.cert-card{background:var(--off-white);border-radius:14px;padding:1.8rem 1.3rem;text-align:center;border:1px solid rgba(0,128,128,.1);transition:all .3s;position:relative;overflow:hidden;box-shadow:0 2px 12px rgba(0,60,60,.06);}
.cert-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--teal),var(--mid-teal));transform:scaleX(0);transition:transform .3s;transform-origin:left;}
.cert-card:hover{transform:translateY(-5px);box-shadow:0 14px 36px rgba(0,70,70,.1);}
.cert-card:hover::before{transform:scaleX(1);}
.cert-icon-wrap{width:60px;height:60px;border-radius:50%;background:var(--light-teal);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:1.6rem;}
.cert-card h3{font-size:.92rem;font-weight:700;color:var(--dark-teal);margin-bottom:.4rem;}
.cert-card p{font-size:.78rem;color:var(--grey);line-height:1.55;}

/* ── PRODUCTS ── */
#products{background:var(--dark-teal);}
.products-wrapper{max-width:1200px;margin:0 auto;}
.products-header{text-align:center;margin-bottom:3rem;}
.products-header .section-title{color:#fff5f7;}
.products-header .section-desc{color:rgba(255,245,247,.55);margin:0 auto;}
.products-header .section-tag{color:#7de0e0;}
.products-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.2rem;}
.product-card{background:rgba(255,245,247,.06);border:1px solid rgba(255,245,247,.1);border-radius:14px;padding:2rem 1.6rem;transition:all .3s;}
.product-card:hover{border-color:rgba(91,200,200,.3);transform:translateY(-4px);}
.product-icon{font-size:2.2rem;margin-bottom:.9rem;}
.product-card h3{font-size:1rem;font-weight:700;color:#fff5f7;margin-bottom:.7rem;}
.product-card p{font-size:.86rem;color:rgba(255,245,247,.58);line-height:1.65;margin-bottom:1rem;}
.product-pills{display:flex;flex-wrap:wrap;gap:.4rem;}
.product-pill{background:rgba(0,128,128,.22);border:1px solid rgba(0,200,200,.18);color:#7de0e0;padding:.22rem .72rem;border-radius:50px;font-size:.72rem;font-weight:500;}

/* ── CLIENTS ── */
/* ── CLIENTS ── */
#clients{
  background:linear-gradient(160deg,#001e1e 0%,#002e2e 40%,#001818 100%);
  position:relative;overflow:hidden;
}
#clients::before{
  content:'';position:absolute;inset:0;
  background-image:
    radial-gradient(ellipse 80% 50% at 50% -10%,rgba(0,128,128,.18) 0%,transparent 70%),
    linear-gradient(rgba(0,128,128,.04) 1px,transparent 1px),
    linear-gradient(90deg,rgba(0,128,128,.04) 1px,transparent 1px);
  background-size:100% 100%,60px 60px,60px 60px;
  pointer-events:none;
}
#clients::after{
  content:'';position:absolute;bottom:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,rgba(91,200,200,.3),transparent);
}
.clients-wrapper{max-width:1200px;margin:0 auto;position:relative;z-index:1;}

/* Header */
.clients-header{text-align:center;margin-bottom:2.5rem;}
.clients-header .section-tag{color:#7de0e0;}
.clients-header .section-title{color:#fff5f7;}
.clients-header .section-desc{color:rgba(255,245,247,.5);margin:0 auto;}

/* Trust strip */
.trust-strip{
  display:flex;justify-content:center;align-items:center;
  flex-wrap:wrap;gap:0;
  background:rgba(255,255,255,.04);
  border:1px solid rgba(91,200,200,.15);
  border-radius:16px;
  padding:.4rem .6rem;
  margin-bottom:3rem;
  backdrop-filter:blur(8px);
}
.trust-item{
  display:flex;align-items:center;gap:.6rem;
  padding:.9rem 2rem;
  position:relative;
  flex:1;min-width:180px;justify-content:center;
}
.trust-item:not(:last-child)::after{
  content:'';position:absolute;right:0;top:20%;height:60%;
  width:1px;background:rgba(91,200,200,.2);
}
.trust-icon{
  font-size:1.5rem;
  filter:drop-shadow(0 0 6px rgba(91,200,200,.4));
}
.trust-text strong{
  display:block;font-size:1.15rem;font-weight:700;
  color:#5bc8c8;font-family:'Playfair Display',serif;
  line-height:1;
}
.trust-text span{
  font-size:.7rem;color:rgba(255,245,247,.45);
  text-transform:uppercase;letter-spacing:.1em;
}

/* Client grid */
.clients-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;}
.client-card{
  position:relative;
  background:rgba(255,255,255,.04);
  border:1px solid rgba(91,200,200,.12);
  border-radius:14px;
  padding:1.4rem 1rem 1.2rem;
  text-align:center;
  cursor:default;
  transition:all .32s cubic-bezier(.4,0,.2,1);
  overflow:hidden;
}
.client-card::before{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(91,200,200,.08) 0%,transparent 60%);
  opacity:0;transition:opacity .32s;
}
.client-card::after{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,var(--teal),#5bc8c8);
  transform:scaleX(0);transform-origin:left;
  transition:transform .35s cubic-bezier(.4,0,.2,1);
}
.client-card:hover{
  border-color:rgba(91,200,200,.35);
  transform:translateY(-6px);
  box-shadow:0 16px 40px rgba(0,0,0,.4),0 0 20px rgba(91,200,200,.08);
  background:rgba(255,255,255,.07);
}
.client-card:hover::before{opacity:1;}
.client-card:hover::after{transform:scaleX(1);}
.client-card-icon{
  width:42px;height:42px;border-radius:10px;
  background:rgba(0,128,128,.2);
  border:1px solid rgba(91,200,200,.2);
  display:flex;align-items:center;justify-content:center;
  font-size:1.1rem;margin:0 auto .85rem;
  transition:all .3s;
}
.client-card:hover .client-card-icon{
  background:rgba(0,128,128,.35);
  border-color:rgba(91,200,200,.4);
  transform:scale(1.08);
}
.client-card-name{
  font-size:.8rem;font-weight:600;
  color:rgba(255,245,247,.82);
  line-height:1.45;
  transition:color .25s;
}
.client-card:hover .client-card-name{color:#fff5f7;}

/* ── CONTACT ── */
#contact{background:linear-gradient(135deg,#002828,#004444);position:relative;overflow:hidden;}
#contact::before{content:'';position:absolute;inset:0;background-image:linear-gradient(rgba(0,128,128,.05) 1px,transparent 1px),linear-gradient(90deg,rgba(0,128,128,.05) 1px,transparent 1px);background-size:50px 50px;}
.contact-wrapper{max-width:1100px;margin:0 auto;position:relative;z-index:1;display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:start;}
.contact-info .section-title{color:#fff5f7;}
.contact-info .section-desc{color:rgba(255,245,247,.55);}
.contact-items{margin-top:2rem;}
.contact-item{display:flex;align-items:flex-start;gap:1rem;margin-bottom:1.3rem;}
.contact-icon-wrap{width:44px;height:44px;border-radius:10px;background:rgba(0,128,128,.22);border:1px solid rgba(0,200,200,.2);display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;}
.contact-item strong{display:block;color:#fff5f7;font-size:.82rem;margin-bottom:.15rem;}
.contact-item span{color:rgba(255,245,247,.5);font-size:.82rem;}
.contact-form{background:rgba(255,245,247,.06);border:1px solid rgba(255,245,247,.1);border-radius:16px;padding:2.2rem;}
.contact-form h3{font-family:'Playfair Display',serif;color:#fff5f7;font-size:1.3rem;margin-bottom:1.5rem;}
.form-group{margin-bottom:1rem;}
.form-group label{display:block;color:rgba(255,245,247,.55);font-size:.7rem;font-weight:600;letter-spacing:.09em;text-transform:uppercase;margin-bottom:.4rem;}
.form-group input,.form-group textarea,.form-group select{width:100%;background:rgba(255,245,247,.08);border:1px solid rgba(255,245,247,.14);border-radius:8px;color:#fff5f7;padding:.75rem 1rem;font-size:.9rem;font-family:'DM Sans',sans-serif;outline:none;transition:border-color .2s;-webkit-appearance:none;}
.form-group select option{background:#004444;color:#fff5f7;}
.form-group input::placeholder,.form-group textarea::placeholder{color:rgba(255,245,247,.28);}
.form-group input:focus,.form-group textarea:focus,.form-group select:focus{border-color:#5bc8c8;}
.form-group textarea{resize:vertical;min-height:90px;}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:1rem;}
.submit-btn{width:100%;background:var(--mid-teal);color:#fff5f7;border:none;border-radius:8px;padding:.9rem;font-size:.92rem;font-weight:600;font-family:'DM Sans',sans-serif;cursor:pointer;transition:all .2s;letter-spacing:.04em;min-height:48px;}
.submit-btn:hover{background:#009999;}
.submit-btn:active{transform:scale(.98);}

/* ── WHATSAPP ── */
.wa-float{position:fixed;bottom:22px;right:18px;z-index:500;background:#25D366;color:#fff5f7;width:56px;height:56px;border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 18px rgba(37,211,102,.45);transition:all .25s;-webkit-tap-highlight-color:transparent;}
.wa-float:hover{transform:scale(1.1);}
.wa-float svg{width:28px;height:28px;fill:#fff5f7;}
.wa-tip{position:absolute;right:64px;top:50%;transform:translateY(-50%);background:#1a1a1a;color:#fff5f7;font-size:.73rem;font-weight:600;padding:.3rem .8rem;border-radius:6px;white-space:nowrap;opacity:0;pointer-events:none;transition:opacity .2s;}
.wa-float:hover .wa-tip{opacity:1;}

/* ── FOOTER ── */
footer{background:#001a1a;padding:2.8rem 6% 1.8rem;border-top:1px solid rgba(0,128,128,.18);}
.footer-inner{max-width:1200px;margin:0 auto;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1.4rem;}
.footer-brand{font-family:'Playfair Display',serif;font-size:1.35rem;color:#fff5f7;font-weight:700;}
.footer-brand span{color:#5bc8c8;}
.footer-brand p{font-size:.88rem;color:rgba(255,245,247,.45);margin-top:.4rem;font-family:'DM Sans',sans-serif;font-weight:400;}
.footer-tagline{color:rgba(255,245,247,.5);font-size:.95rem;font-style:italic;}
.footer-links{display:flex;gap:1.4rem;flex-wrap:wrap;}
.footer-links a{color:rgba(255,245,247,.45);font-size:.88rem;transition:color .2s;}
.footer-links a:hover{color:#5bc8c8;}

/* ── SCROLL REVEAL ── */
.reveal{opacity:0;transform:translateY(28px);transition:opacity .7s ease,transform .7s ease;}
.reveal.visible{opacity:1;transform:translateY(0);}
.reveal-delay-1{transition-delay:.1s;}
.reveal-delay-2{transition-delay:.2s;}
.reveal-delay-3{transition-delay:.3s;}
.reveal-delay-4{transition-delay:.4s;}

/* ── TABLET ── */
@media(max-width:1024px){
  .cert-grid{grid-template-columns:repeat(2,1fr);}
  .clients-grid{grid-template-columns:repeat(3,1fr);}
  .trust-strip{gap:0;}
  .about-grid{gap:2.5rem;}
}
/* ── MOBILE ── */
@media(max-width:768px){
  .nav-links,.nav-cta{display:none;}
  .hamburger{display:flex;}
